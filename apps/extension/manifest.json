{
  "manifest_version": 3,
  "name": "AliSum — AliExpress Expense Tracker",
  "version": "1.0.0",
  "description": "Sync your AliExpress order history for expense analytics",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["https://*.aliexpress.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.aliexpress.com/p/order/*"],
      "js": ["dist/scraper.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
